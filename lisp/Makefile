SRC_DIR=.

.PHONY: tests
tests: now-playing-tests

.PHONY: now-playing-tests
now-playing-tests:
	$(MAKE) -C $(SRC_DIR) -f Makefile-now-playing.make tests

.PHONY: package-lint
package-lint:
	$(MAKE) -C $(SRC_DIR) -f Makefile-now-playing.make $@

.PHONY: regression
regression:
	$(MAKE) -C $(SRC_DIR) -f Makefile-now-playing.make $@

.PHONY: clean
clean:
	$(MAKE) -C $(SRC_DIR) -f Makefile-now-playing.make $@
